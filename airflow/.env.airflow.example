# Airflow home PC configuration for ApplyLuma Phase 10A
# Copy this to .env.airflow and fill in your Railway/production credentials.
# Never commit .env.airflow — it is gitignored.

# --- Railway PostgreSQL (same DB as production) ---
AIRFLOW__DATABASE__SQLALCHEMY_CONN=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB

# --- Railway Redis (same broker as production Celery) ---
AIRFLOW__CELERY__BROKER_URL=redis://:PASSWORD@HOST:PORT/0
AIRFLOW__CELERY__RESULT_BACKEND=redis://:PASSWORD@HOST:PORT/0

# --- Airflow Postgres connection (for DAG operators) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
AIRFLOW_CONN_POSTGRES_DEFAULT=postgresql://USER:PASSWORD@HOST:PORT/DB

# --- Fernet key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
AIRFLOW__CORE__FERNET_KEY=

# --- Swedish job board API keys ---

# Platsbanken / JobTech Dev API
# Register at: https://jobtech.se/api
# Basic search works without a key; a key increases rate limits.
PLATSBANKEN_API_KEY=

# Adzuna API (used for Indeed.se results)
# Register at: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_API_KEY=
