{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run type-check)",
      "Bash(ruff check *)",
      "Bash(pip show *)",
      "Bash(pip3 show *)",
      "Bash(pip list *)",
      "Bash(pip3 list *)"
    ]
  }
}
