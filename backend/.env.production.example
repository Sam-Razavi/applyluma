# ============================================
# ApplyLuma Backend - Production Environment
# ============================================
# DO NOT commit real production values.
# Copy to .env.production locally if needed, and add real values in Railway.

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# Redis (Railway provides this automatically)
REDIS_URL=redis://host:port

# Adzuna Job Search API
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# OpenAI API (for resume analysis)
OPENAI_API_KEY=your_openai_api_key

# JWT Authentication
SECRET_KEY=your_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Settings
ENVIRONMENT=production
RATE_LIMIT_PER_MINUTE=60
ANALYTICS_CACHE_TTL_HOURS=1

# CORS (JSON list for pydantic-settings)
BACKEND_CORS_ORIGINS=["https://applyluma.com","https://www.applyluma.com"]

# File Upload
STORAGE_DIR=/app/storage
MAX_UPLOAD_BYTES=10485760

