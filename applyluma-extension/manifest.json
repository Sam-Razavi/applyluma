{
  "manifest_version": 3,
  "name": "ApplyLuma",
  "version": "0.6.0",
  "description": "Save job postings from LinkedIn, Indeed, Glassdoor, and Arbetsförmedlingen to ApplyLuma with one click.",
  "homepage_url": "https://applyluma.com",
  "permissions": ["storage", "tabs", "alarms", "notifications"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "applyluma@applyluma.com",
      "strict_min_version": "109.0"
    }
  },
  "commands": {
    "quick-save": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current job to ApplyLuma"
    }
  },
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://se.indeed.com/*",
    "https://www.indeed.com/*",
    "https://arbetsformedlingen.se/*",
    "https://www.arbetsformedlingen.se/*",
    "https://www.glassdoor.com/*",
    "https://applyluma-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://se.indeed.com/*", "https://www.indeed.com/*"],
      "js": ["content/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://arbetsformedlingen.se/*"],
      "js": ["content/platsbanken.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.glassdoor.com/*"],
      "js": ["content/glassdoor.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ApplyLuma",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
