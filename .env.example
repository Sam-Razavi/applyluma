# ─── Application ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string-in-production
ENVIRONMENT=development

# ─── Database ────────────────────────────────────────────────────────────────
# Use a strong, unique password in production.
POSTGRES_USER=applyluma
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=applyluma
DATABASE_URL=postgresql://applyluma:change-me-in-production@localhost:5432/applyluma

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ─────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── Airflow (required when running docker-compose) ─────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Generate secret key: openssl rand -hex 32
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-in-production
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_METADATA_USER=airflow
AIRFLOW_METADATA_PASSWORD=change-me-in-production
AIRFLOW_METADATA_DB=airflow_db

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# Use the test keys below for local development only (always pass).
# Replace with real keys from https://dash.cloudflare.com for production.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
